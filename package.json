{
  "name": "oracle-plus",
  "version": "1.0.0",
  "private": true,
  
  "main": "expo-router/entry",
  
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    
    "dev": "expo start --dev-client",
    
    "ts:check": "tsc --noEmit",
    
    "build:web": "expo export --platform web",
    
    "clear": "expo start -c",
    
    "lint": "expo lint"
  },
  
  "dependencies": {
    "expo": "~51.0.0",
    
    "react": "18.2.0",
    "react-native": "0.74.5",
    
    "expo-router": "~3.5.23",
    
    "@expo/vector-icons": "^14.0.2",
    
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native-stack": "^6.9.26",
    
    "react-native-screens": "3.31.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-speech": "~13.0.1",
    "expo-status-bar": "~1.12.1",
    
    "react-native-svg": "15.2.0",
    
    "react-native-web": "~0.19.10",
    "react-dom": "18.2.0"
  },
  
  "devDependencies": {
    "@babel/core": "^7.20.0",
    
    "@types/react": "~18.2.45",
    
    "typescript": "~5.3.3"
  },
  
  "expo": {
    "name": "Oracle Plus",
    
    "slug": "oracle-plus",
    
    "scheme": "oracle-plus",
    
    "version": "1.0.0",
    
    "orientation": "portrait",
    
    "userInterfaceStyle": "automatic",
    
    "newArchEnabled": true,
    
    "plugins": [
      "expo-router"
    ],
    
    "experiments": {
      "typedRoutes": true
    },
    
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    
    "assetBundlePatterns": [
      "**/*"
    ],
    
    "android": {
      "package": "com.oracleplus.app",
      
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    
    "ios": {
      "supportsTablet": true,
      
      "bundleIdentifier": "com.oracleplus.app"
    },
    
    "web": {
      "bundler": "metro",
      
      "output": "static",
      
      "favicon": "./assets/favicon.png"
    },
    
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}