# Oracle Plus — Variables d'environnement (exemple)
# Copier ce fichier en .env et remplir les valeurs

EXPO_PUBLIC_API_BASE_URL=http://localhost:4200
EXPO_PUBLIC_APP_URL=https://oracleplus.app

# Email de l'administrateur (accès au menu Livres dans le profil)
EXPO_PUBLIC_ADMIN_EMAIL=chingankonggeorges@gmail.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
