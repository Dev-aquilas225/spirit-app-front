{
  "expo": {
    "name": "Oracle Plus",
    "slug": "oracle-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oracleplus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oracleplus.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A3E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.oracleplus.android"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "meta": {
        "description": "Votre compagnon spirituel — Prières, Livres et Formations",
        "author": "Oracle Plus",
        "themeColor": "#C9A84C",
        "appleMobileWebAppCapable": "yes",
        "appleMobileWebAppStatusBarStyle": "black-translucent",
        "appleMobileWebAppTitle": "Oracle Plus"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A3E",
          "dark": {
            "backgroundColor": "#0D0D2B"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C9A84C",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
